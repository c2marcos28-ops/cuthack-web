---
import { SITE_TITLE, SITE_TAGLINE } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="footer-brand">
			<div class="footer-name">{SITE_TITLE}</div>
			<div class="footer-tagline">{SITE_TAGLINE}</div>
		</div>
		<nav class="footer-nav">
			<a href="/articles">記事一覧</a>
			<a href="/about">About</a>
			<a href="/rss.xml">RSS</a>
		</nav>
	</div>
	<div class="copyright">
		&copy; {today.getFullYear()} {SITE_TITLE} ・ Powered by 株式会社LunoX
	</div>
</footer>
<style>
	footer {
		padding: 3em 1em 4em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
	}
	.footer-content {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;
		gap: 2em;
		margin-bottom: 2em;
	}
	.footer-name {
		font-size: 1.5em;
		font-weight: 800;
		color: rgb(var(--gray-dark));
	}
	.footer-tagline {
		font-size: 0.95em;
		color: rgb(var(--gray));
	}
	.footer-nav {
		display: flex;
		gap: 1.5em;
	}
	.footer-nav a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	.footer-nav a:hover {
		color: rgb(var(--accent));
	}
	.copyright {
		text-align: center;
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
	@media (max-width: 600px) {
		.footer-content {
			flex-direction: column;
			text-align: center;
			gap: 1em;
		}
	}
</style>
