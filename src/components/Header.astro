---
import { SITE_TITLE, SITE_TAGLINE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="brand">
			<a href="/" class="brand-link">
				<span class="brand-name">{SITE_TITLE}</span>
				<span class="brand-tagline">{SITE_TAGLINE}</span>
			</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/articles">記事一覧</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	.brand-link {
		display: flex;
		align-items: baseline;
		gap: 0.75em;
		text-decoration: none;
		color: rgb(var(--black));
		padding: 0.75em 0;
	}
	.brand-name {
		font-size: 1.5em;
		font-weight: 800;
		letter-spacing: -0.02em;
	}
	.brand-tagline {
		font-size: 0.85em;
		color: rgb(var(--gray));
		font-weight: 400;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
		flex-wrap: wrap;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	@media (max-width: 600px) {
		.brand-tagline {
			display: none;
		}
		.brand-name {
			font-size: 1.25em;
		}
	}
</style>
