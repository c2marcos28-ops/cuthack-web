---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getCategory } from '../consts';

type Props = CollectionEntry<'articles'>['data'];

const {
	title,
	description,
	publishedAt,
	updatedAt,
	heroImage,
	heroImageAlt,
	category,
	tags,
	author,
	authorType,
	isExperienceArticle,
	sourceUrls,
} = Astro.props;

const categoryInfo = getCategory(category);
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1.3;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.meta {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.category-badge {
				display: inline-block;
				padding: 0.25em 0.75em;
				background: rgba(var(--accent), 0.1);
				color: rgb(var(--accent));
				border-radius: 999px;
				font-size: 0.85em;
				font-weight: 600;
				margin-bottom: 0.75em;
				text-decoration: none;
			}
			.last-updated-on {
				font-style: italic;
			}
			.tags {
				margin: 0.5em 0;
			}
			.tag {
				display: inline-block;
				padding: 0.15em 0.6em;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				border-radius: 4px;
				font-size: 0.8em;
				margin-right: 0.3em;
			}
			.ai-disclaimer {
				background: rgba(var(--gray), 0.08);
				border-left: 4px solid rgb(var(--gray));
				padding: 0.75em 1em;
				margin: 1em 0;
				font-size: 0.9em;
				color: rgb(var(--gray-dark));
				border-radius: 4px;
			}
			.experience-badge {
				background: rgba(var(--accent), 0.08);
				border-left: 4px solid rgb(var(--accent));
				padding: 0.75em 1em;
				margin: 1em 0;
				font-size: 0.9em;
				border-radius: 4px;
			}
			.sources {
				margin-top: 3em;
				padding: 1em;
				background: rgb(var(--gray-light));
				border-radius: 8px;
			}
			.sources h3 {
				margin-top: 0;
				font-size: 1em;
			}
			.sources ul {
				margin: 0.5em 0;
				padding-left: 1.5em;
			}
			.sources a {
				font-size: 0.9em;
				word-break: break-all;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{
					heroImage && (
						<div class="hero-image">
							<Image
								width={1020}
								height={510}
								src={heroImage}
								alt={heroImageAlt ?? title}
							/>
						</div>
					)
				}
				<div class="prose">
					<div class="title">
						{
							categoryInfo && (
								<a class="category-badge" href={`/${category}/`}>
									{categoryInfo.emoji} {categoryInfo.name}
								</a>
							)
						}
						<h1>{title}</h1>
						<div class="meta">
							<FormattedDate date={publishedAt} />
							{
								updatedAt && (
									<span class="last-updated-on">
										{' '}
										・ 最終更新 <FormattedDate date={updatedAt} />
									</span>
								)
							}
						</div>
						{
							tags && tags.length > 0 && (
								<div class="tags">
									{tags.map((tag) => (
										<span class="tag">#{tag}</span>
									))}
								</div>
							)
						}
						<hr />
					</div>

					{
						authorType === 'auto' && !isExperienceArticle && (
							<div class="ai-disclaimer">
								ⓘ 本記事は公式情報・公開デモを元にAIが整理しました。筆者個人の使用体験ではない点にご注意ください。
							</div>
						)
					}

					{
						isExperienceArticle && (
							<div class="experience-badge">
								✍️ <strong>マルコス（SEED代表・現役動画編集者）の実体験記事</strong> /
								動画編集の現場で日々手を動かしながら書いてます。
							</div>
						)
					}

					<slot />

					{
						sourceUrls && sourceUrls.length > 0 && (
							<div class="sources">
								<h3>📚 出典・参考情報</h3>
								<ul>
									{sourceUrls.map((url) => (
										<li>
											<a href={url} target="_blank" rel="noopener noreferrer">
												{url}
											</a>
										</li>
									))}
								</ul>
							</div>
						)
					}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
