---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE, getCategory } from '../consts';

// 最新記事を6件取得
const latestArticles = (await getCollection('articles', ({ data }) => !data.draft))
	.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
	.slice(0, 6);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`${SITE_TITLE} - ${SITE_TAGLINE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.hero {
				background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
				color: white;
				padding: 5em 1em 4em;
				text-align: center;
			}
			.hero h1 {
				font-size: 3.5rem;
				margin: 0 0 0.3em;
				letter-spacing: -0.02em;
				line-height: 1.1;
				color: white;
			}
			.hero .tagline {
				font-size: 1.5rem;
				margin: 0 0 0.8em;
				color: #a8e6cf;
				font-weight: 600;
			}
			.hero .description {
				font-size: 1.1rem;
				max-width: 680px;
				margin: 0 auto;
				color: #ccc;
				line-height: 1.6;
			}
			.hero-cta {
				margin-top: 2em;
			}
			.cta-button {
				display: inline-block;
				padding: 0.8em 2em;
				background: #a8e6cf;
				color: #1a1a1a;
				border-radius: 999px;
				font-weight: 700;
				text-decoration: none;
				transition: 0.2s ease;
			}
			.cta-button:hover {
				background: #8edab2;
				transform: translateY(-2px);
			}
			.section {
				max-width: 1100px;
				margin: 0 auto;
				padding: 4em 1em;
			}
			.section-title {
				font-size: 1.8rem;
				margin: 0 0 1.5em;
				text-align: center;
			}
			.section-title .underline {
				display: inline-block;
				border-bottom: 4px solid rgb(var(--accent));
				padding-bottom: 0.2em;
			}
			.categories-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
				gap: 1em;
			}
			.category-card {
				display: block;
				padding: 1.2em;
				background: white;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				text-decoration: none;
				color: rgb(var(--black));
				transition: 0.2s ease;
			}
			.category-card:hover {
				border-color: rgb(var(--accent));
				transform: translateY(-2px);
				box-shadow: var(--box-shadow);
			}
			.category-card .emoji {
				font-size: 2em;
				display: block;
				margin-bottom: 0.3em;
			}
			.category-card .name {
				font-weight: 700;
				margin: 0 0 0.3em;
				font-size: 1.05em;
			}
			.category-card .desc {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin: 0;
				line-height: 1.5;
			}
			.articles-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5em;
			}
			.article-card {
				background: white;
				border-radius: 12px;
				overflow: hidden;
				border: 1px solid rgb(var(--gray-light));
				text-decoration: none;
				color: inherit;
				transition: 0.2s ease;
			}
			.article-card:hover {
				transform: translateY(-2px);
				box-shadow: var(--box-shadow);
			}
			.article-card-body {
				padding: 1em;
			}
			.article-card .cat {
				font-size: 0.8em;
				color: rgb(var(--accent));
				font-weight: 600;
				margin: 0 0 0.4em;
			}
			.article-card .title {
				font-size: 1.05em;
				font-weight: 700;
				margin: 0 0 0.5em;
				line-height: 1.4;
				color: rgb(var(--black));
			}
			.article-card .date {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin: 0;
			}
			.empty-articles {
				text-align: center;
				padding: 3em 1em;
				color: rgb(var(--gray));
				background: rgb(var(--gray-light));
				border-radius: 12px;
			}
			.about-section {
				background: rgb(var(--gray-light));
				padding: 4em 1em;
			}
			.about-content {
				max-width: 760px;
				margin: 0 auto;
				text-align: center;
			}
			.about-content p {
				font-size: 1.05em;
				line-height: 1.8;
			}
			@media (max-width: 720px) {
				.hero h1 {
					font-size: 2.5rem;
				}
				.hero .tagline {
					font-size: 1.2rem;
				}
				.hero .description {
					font-size: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- HERO -->
			<section class="hero">
				<h1>{SITE_TITLE}</h1>
				<p class="tagline">{SITE_TAGLINE}</p>
				<p class="description">
					動画編集の <strong>最新情報</strong> と <strong>効率化のテク</strong> を、ひとつにまとめる。<br />
					AI・ツール・ノウハウを、現役動画編集者の視点で毎日アップデート。
				</p>
				<div class="hero-cta">
					<a href="/articles" class="cta-button">📰 すべての記事を見る</a>
				</div>
			</section>

			<!-- カテゴリ -->
			<section class="section">
				<h2 class="section-title"><span class="underline">📚 カテゴリ</span></h2>
				<div class="categories-grid">
					{
						CATEGORIES.map((cat) => (
							<a class="category-card" href={`/${cat.slug}/`}>
								<span class="emoji">{cat.emoji}</span>
								<p class="name">{cat.name}</p>
								<p class="desc">{cat.description}</p>
							</a>
						))
					}
				</div>
			</section>

			<!-- 最新記事 -->
			<section class="section">
				<h2 class="section-title"><span class="underline">🆕 最新記事</span></h2>
				{
					latestArticles.length === 0 ? (
						<div class="empty-articles">
							<p>記事を準備中です。<br />まもなく毎日更新が始まります。</p>
						</div>
					) : (
						<div class="articles-grid">
							{latestArticles.map((article) => {
								const cat = getCategory(article.data.category);
								return (
									<a class="article-card" href={`/articles/${article.id}/`}>
										<div class="article-card-body">
											<p class="cat">
												{cat?.emoji} {cat?.name}
											</p>
											<h3 class="title">{article.data.title}</h3>
											<p class="date">
												<FormattedDate date={article.data.publishedAt} />
											</p>
										</div>
									</a>
								);
							})}
						</div>
					)
				}
			</section>

			<!-- About -->
			<section class="about-section">
				<div class="about-content">
					<h2 class="section-title">
						<span class="underline">Cut Hack について</span>
					</h2>
					<p>
						動画編集の <strong>最新情報</strong> と <strong>効率化のためのテク</strong> を、<br />
						ひとつにまとめる場所です。<br /><br />
						AI・ツール・ノウハウ・トレンドを、<br />
						<strong>現役動画編集者の視点</strong> で実務目線でまとめて毎日お届けします。
					</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
